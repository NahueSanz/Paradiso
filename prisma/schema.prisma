generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
}

enum Role {
  owner
  employee
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  name        String
  role        Role         @default(employee)
  clubs       Club[]
  clubId      Int?
  club        Club?        @relation("EmployeeClub", fields: [clubId], references: [id])
  memberships Membership[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum ReservationStatus {
  pending
  confirmed
  cancelled
}

enum ReservationType {
  booking
  class
  tournament
  challenge
}

enum PaymentStatus {
  pending
  partial
  paid
}

enum PlayStatus {
  scheduled
  playing
  finished
}

model Club {
  id             Int             @id @default(autoincrement())
  name           String
  ownerId        Int
  owner          User            @relation(fields: [ownerId], references: [id])
  employees      User[]          @relation("EmployeeClub")
  courts         Court[]
  invitations    Invitation[]
  memberships    Membership[]
  cashMovements  CashMovement[]
  products       Product[]
  movements      Movement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Invitation {
  id          Int       @id @default(autoincrement())
  email       String
  clubId      Int
  club        Club      @relation(fields: [clubId], references: [id])
  role        Role      @default(employee)
  token       String    @unique
  displayName String?
  createdAt   DateTime  @default(now())
  acceptedAt  DateTime?
}

model Membership {
  id          Int    @id @default(autoincrement())
  userId      Int
  clubId      Int
  role        Role
  displayName String

  user        User   @relation(fields: [userId], references: [id])
  club        Club   @relation(fields: [clubId], references: [id])

  createdReservations Reservation[] @relation("CreatedBy")
  updatedReservations Reservation[] @relation("UpdatedBy")

  @@unique([userId, clubId])
}

model Court {
  id                Int                @id @default(autoincrement())
  name              String
  clubId            Int
  club              Club               @relation(fields: [clubId], references: [id])
  reservations      Reservation[]
  fixedReservations FixedReservation[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model FixedReservation {
  id            Int      @id @default(autoincrement())
  courtId       Int
  court         Court    @relation(fields: [courtId], references: [id])
  dayOfWeek     Int      // 0-6 (Sunday-Saturday)
  timeStart     String   // "HH:MM"
  duration      Int      // minutes
  clientName    String
  type          String
  totalPrice    Decimal? @db.Decimal(10, 2)
  depositAmount Decimal? @db.Decimal(10, 2)
  carryOver     Decimal   @default(0) @db.Decimal(10, 2)
  lastPaidAt    DateTime?
  active        Boolean   @default(true)

  createdAt     DateTime  @default(now())
}

model Product {
  id              Int              @id @default(autoincrement())
  name            String
  salePrice       Decimal          @db.Decimal(10, 2)
  purchasePrice   Decimal          @default(0) @db.Decimal(10, 2)
  stock           Int              @default(0)
  clubId          Int
  club            Club             @relation(fields: [clubId], references: [id])
  cashMovements   CashMovement[]
  stockMovements  StockMovement[]
  movements       Movement[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  productId Int
  quantity  Int      // negative = sale, positive = restock
  type      String   // "sale" | "restock"
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id])
}

model CashMovement {
  id                   Int      @id @default(autoincrement())
  clubId               Int
  club                 Club     @relation(fields: [clubId], references: [id])
  type                 String   // "income" | "expense"
  concept              String
  amount               Decimal  @db.Decimal(10, 2)
  paymentMethod        String
  relatedReservationId Int?
  fixedReservationId   Int?
  relatedProductId     Int?
  product              Product? @relation(fields: [relatedProductId], references: [id])
  createdAt            DateTime @default(now())
}

model Movement {
  id            Int      @id @default(autoincrement())
  clubId        Int
  club          Club     @relation(fields: [clubId], references: [id])
  type          String   // "sale" | "manual"
  amount        Decimal  @db.Decimal(10, 2)
  description   String
  productId     Int?
  product       Product? @relation(fields: [productId], references: [id])
  quantity      Int?
  status        String   @default("active") // "active" | "cancelled"
  paymentMethod String   @default("cash")   // "cash" | "mercadopago"
  createdAt     DateTime @default(now())
}

model Reservation {
  id                    Int               @id @default(autoincrement())
  courtId               Int
  court                 Court             @relation(fields: [courtId], references: [id])
  date                  DateTime          @db.Date
  timeStart             DateTime          @db.Time
  timeEnd               DateTime          @db.Time
  clientName            String
  clientPhone           String?
  type                  ReservationType   @default(booking)
  status                ReservationStatus @default(pending)
  totalPrice            Decimal?          @db.Decimal(10, 2)
  depositAmount         Decimal?          @db.Decimal(10, 2)
  paidAmount            Decimal?          @db.Decimal(10, 2)
  paymentStatus         PaymentStatus     @default(pending)
  playStatus            PlayStatus        @default(scheduled)
  createdByMembershipId Int?
  updatedByMembershipId Int?
  createdByMembership   Membership?       @relation("CreatedBy", fields: [createdByMembershipId], references: [id])
  updatedByMembership   Membership?       @relation("UpdatedBy", fields: [updatedByMembershipId], references: [id])
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}
