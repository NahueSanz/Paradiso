generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
}

enum Role {
  owner
  employee
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  name        String
  role        Role         @default(employee)
  clubs       Club[]
  clubId      Int?
  club        Club?        @relation("EmployeeClub", fields: [clubId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum ReservationStatus {
  pending
  confirmed
  cancelled
}

enum ReservationType {
  booking
  class
  tournament
  challenge
}

enum PaymentStatus {
  pending
  partial
  paid
}

enum PlayStatus {
  scheduled
  playing
  finished
}

model Club {
  id          Int          @id @default(autoincrement())
  name        String
  ownerId     Int
  owner       User         @relation(fields: [ownerId], references: [id])
  employees   User[]       @relation("EmployeeClub")
  courts      Court[]
  invitations Invitation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Invitation {
  id         Int       @id @default(autoincrement())
  email      String
  clubId     Int
  club       Club      @relation(fields: [clubId], references: [id])
  role       Role      @default(employee)
  token      String    @unique
  createdAt  DateTime  @default(now())
  acceptedAt DateTime?
}

model Court {
  id           Int           @id @default(autoincrement())
  name         String
  clubId       Int
  club         Club          @relation(fields: [clubId], references: [id])
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Reservation {
  id            Int               @id @default(autoincrement())
  courtId       Int
  court         Court             @relation(fields: [courtId], references: [id])
  date          DateTime          @db.Date
  timeStart     DateTime          @db.Time
  timeEnd       DateTime          @db.Time
  clientName    String
  clientPhone   String?
  type          ReservationType   @default(booking)
  status        ReservationStatus @default(pending)
  totalPrice    Decimal?          @db.Decimal(10, 2)
  depositAmount Decimal?          @db.Decimal(10, 2)
  paymentStatus PaymentStatus     @default(pending)
  playStatus    PlayStatus        @default(scheduled)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}
